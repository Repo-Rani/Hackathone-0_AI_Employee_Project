{
  "test": {
    "environment": "jsdom",
    "globals": true,
    "setupFiles": ["./tests/setup.ts"],
    "include": ["tests/**/*.{test,spec}.{ts,tsx}"],
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "json", "html"],
      "exclude": [
        "node_modules/",
        "tests/"
      ]
    }
  }
}
